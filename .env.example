# Environment Variables Template
# Copy this file to .env and fill in the values

# Path to the directory containing Blender manual HTML files for indexing
DOCS_DIR=./blender_manual_html

# Paths for the local database and vector index
DB_PATH=./data/blender_meta.db
FAISS_PATH=./data/blender_vectors.index

# Markdown chunk size for documentation indexing
CHUNK_SIZE=600

# MCP execution mode (default: stdio)
MCP_MODE=stdio

# Local port for the Blender bridge server
BLENDER_PORT=5000
